{
  "name": "pink-ward",
  "version": "0.1.0",
  "description": "Pink Ward desktop workspace shell",
  "main": "main.js",
  "author": "Pink Ward",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win dir --x64"
  },
  "build": {
    "appId": "local.pinkward.workspace",
    "productName": "Pink Ward",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "inference/**/*",
      "scripts/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "inference/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "runtime/python",
        "to": "runtime/python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
